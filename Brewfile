# prettiest — modern CLI toolset + pretty glue (macOS).
# Installed via `brew bundle --file Brewfile` (run by `prettiest install`).

# Core modern replacements (the user's list)
brew "eza"        # ls
brew "bat"        # cat
brew "git-delta"  # git diff pager
brew "duf"        # df
brew "dust"       # du
brew "procs"      # ps
brew "fd"         # find
brew "ripgrep"    # grep
brew "btop"       # top/htop

# Pretty glue / navigation
brew "starship"   # prompt
brew "fzf"        # fuzzy finder
brew "zoxide"     # smart cd

# Icons/glyphs for eza + starship (Nerd Font)
cask "font-meslo-lg-nerd-font"
