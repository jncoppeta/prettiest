#!/usr/bin/env bash
# prettiest — bundle modern CLI tools + coordinated pretty (Catppuccin) configs.
#   install | doctor | theme <mocha|macchiato|frappe|latte> | uninstall | help
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SRC="$ROOT/config"
XDG="${XDG_CONFIG_HOME:-$HOME/.config}"
DEST="$XDG/prettiest"
MARKER="prettiest"
TOOLS="eza bat git-delta duf dust procs fd ripgrep btop starship fzf zoxide"
COLORWAYS="catppuccin gruvbox tokyonight mono"   # matches system-hud's colorway set

# ---------- pretty logging (uses gum if present) ----------
c(){ printf '\033[%sm%s\033[0m' "$1" "$2"; }
say(){ printf '%s %s\n' "$(c '38;5;183' '◆')" "$1"; }
ok(){  printf '%s %s\n' "$(c '38;5;120' '✓')" "$1"; }
warn(){ printf '%s %s\n' "$(c '38;5;215' '▲')" "$1" >&2; }
die(){  printf '%s %s\n' "$(c '38;5;210' '✗')" "$1" >&2; exit 1; }

os(){ case "$(uname -s)" in Darwin) echo mac;; Linux) echo linux;; *) echo other;; esac; }
have(){ command -v "$1" >/dev/null 2>&1; }
backup(){ [ -f "$1" ] || return 0; cp "$1" "$1.bak.$(date +%Y%m%d%H%M%S)"; say "backed up $1"; }

# ---------- install: tools ----------
RUST_TOOLS="eza ripgrep fd-find bat git-delta du-dust procs zoxide starship"  # cargo crate names
install_rust_prebuilt(){ # fast prebuilt binaries; avoids brew source builds (e.g. eza->pandoc->GHC)
  have cargo || { warn "cargo not found — install rustup for fast prebuilt installs"; return 1; }
  if ! command -v cargo-binstall >/dev/null 2>&1 && [ ! -x "$HOME/.cargo/bin/cargo-binstall" ]; then
    say "installing cargo-binstall…"
    curl -L --proto '=https' --tlsv1.2 -fsSf https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash
  fi
  "$HOME/.cargo/bin/cargo-binstall" -y $RUST_TOOLS || warn "some prebuilt installs failed"
}
install_tools(){
  say "installing tools…"
  if [ "$(os)" = mac ]; then
    have brew || die "Homebrew required — see https://brew.sh"
    # Rust tools: prebuilt binaries (brew would source-build eza->pandoc->GHC on older macOS).
    if ! install_rust_prebuilt; then
      warn "falling back to brew bundle (may compile from source)"; brew bundle --file "$ROOT/Brewfile"
    fi
    # Non-Rust + font via brew (bottled/quick); btop is optional (C++ source build on old macOS).
    brew list --cask font-meslo-lg-nerd-font >/dev/null 2>&1 || brew install --cask font-meslo-lg-nerd-font || warn "font cask failed"
    have duf || brew install duf || warn "duf failed"
    have fzf || brew install fzf || warn "fzf failed"
    have btop || warn "btop optional & not installed — add later with: brew install btop"
  elif [ "$(os)" = linux ]; then
    if have apt-get; then
      sudo apt-get update -qq || true
      # apt-available packages from packages.txt (col 2 != -)
      apt=$(awk '!/^#/ && $2!="-"{print $2}' "$ROOT/packages.txt")
      sudo apt-get install -y $apt || warn "some apt packages failed"
    fi
    if have cargo; then
      crates=$(awk '!/^#/ && $3!="-"{print $3}' "$ROOT/packages.txt")
      for cr in $crates; do have "${cr/du-dust/dust}" || cargo install "$cr" || warn "cargo $cr failed"; done
    else
      warn "cargo not found — install rustup for eza/git-delta/dust/procs/zoxide"
    fi
    have starship || curl -fsSL https://starship.rs/install.sh | sh -s -- -y || warn "starship install failed"
  else
    die "unsupported OS"
  fi
  ok "tools step done"
}

# ---------- install: configs ----------
install_configs(){
  say "placing configs into ${DEST}…"
  mkdir -p "$DEST" "$XDG/bat/themes" "$XDG/btop/themes"
  cp "$SRC/prettiest.sh" "$DEST/prettiest.sh"
  # starship
  backup "$XDG/starship.toml"; cp "$SRC/starship.toml" "$XDG/starship.toml"
  # bat
  cp "$SRC/bat/config" "$XDG/bat/config"
  ok "configs placed"
}

# ---------- install: Catppuccin theme files (fetched from upstream) ----------
fetch(){ curl -fsSL "$1" -o "$2" 2>/dev/null && return 0 || return 1; }
install_themes(){
  say "fetching themes (catppuccin colorway needs upstream files; others use built-ins)…"
  # bat: catppuccin needs the .tmTheme; gruvbox-dark/ansi/TwoDark are bat built-ins.
  fetch "https://raw.githubusercontent.com/catppuccin/bat/main/themes/Catppuccin%20Mocha.tmTheme" \
        "$XDG/bat/themes/Catppuccin Mocha.tmTheme" || warn "bat catppuccin theme fetch failed"
  if have bat; then bat cache --build >/dev/null 2>&1 && ok "bat theme cache built" || warn "bat cache build failed"; fi
  # btop: catppuccin theme file; gruvbox_dark/greyscale ship with btop; tokyo-night best-effort.
  fetch "https://raw.githubusercontent.com/catppuccin/btop/main/themes/catppuccin_mocha.theme" \
        "$XDG/btop/themes/catppuccin_mocha.theme" || warn "btop catppuccin theme fetch failed"
  # delta: catppuccin feature definitions.
  mkdir -p "$DEST/delta"
  fetch "https://raw.githubusercontent.com/catppuccin/delta/main/catppuccin.gitconfig" \
        "$DEST/delta/catppuccin.gitconfig" || warn "delta catppuccin theme fetch failed"
  ok "themes fetched"
}

# ---------- wiring: shell rc ----------
wire_shell(){
  local line="[ -f \"$DEST/prettiest.sh\" ] && source \"$DEST/prettiest.sh\"  # $MARKER"
  for rc in "$HOME/.zshrc" "$HOME/.bashrc"; do
    [ -e "$rc" ] || { [ "$rc" = "$HOME/.zshrc" ] && touch "$rc" || continue; }
    if grep -q "# $MARKER\$" "$rc" 2>/dev/null; then
      say "$(basename "$rc") already wired"
    else
      backup "$rc"; printf '\n%s\n' "$line" >> "$rc"; ok "wired $(basename "$rc")"
    fi
  done
}

# ---------- wiring: git (delta) ----------
write_delta_active(){ # $1 = colorway
  local active="$DEST/delta/active.gitconfig" cw="$1" bat_theme
  mkdir -p "$DEST/delta"
  case "$cw" in
    gruvbox) bat_theme="gruvbox-dark" ;;
    tokyonight) bat_theme="TwoDark" ;;
    mono) bat_theme="ansi" ;;
    *) bat_theme="Catppuccin Mocha" ;;
  esac
  if [ "$cw" = catppuccin ] && [ -f "$DEST/delta/catppuccin.gitconfig" ]; then
    # full Catppuccin delta feature set
    cat > "$active" <<EOF
# prettiest — delta wiring. Regenerated by \`prettiest theme\`.
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	features = catppuccin-mocha
[include]
	path = $DEST/delta/catppuccin.gitconfig
EOF
  else
    # other colorways: drive delta's syntax highlighting off the matching bat theme
    cat > "$active" <<EOF
# prettiest — delta wiring ($cw). Regenerated by \`prettiest theme\`.
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	syntax-theme = $bat_theme
EOF
  fi
}
wire_git(){
  local active="$DEST/delta/active.gitconfig"
  write_delta_active "$(cat "$DEST/theme" 2>/dev/null || echo catppuccin)"
  local gc="$HOME/.gitconfig"
  if grep -q "delta/active.gitconfig" "$gc" 2>/dev/null; then
    say "git already wired for delta"
  else
    backup "$gc"
    printf '\n# --- %s (delta diffs) ---\n[include]\n\tpath = %s\n' "$MARKER" "$active" >> "$gc"
    ok "wired git pager -> delta"
  fi
}

cmd_install(){
  local wire=1
  [ "${1:-}" = "--no-wire" ] && wire=0
  install_tools
  install_configs
  install_themes
  [ -f "$DEST/theme" ] || echo "catppuccin" > "$DEST/theme"
  if [ "$wire" = 1 ]; then
    wire_shell
    wire_git
    echo
    ok "prettiest installed. Restart your shell, or:  source \"$DEST/prettiest.sh\""
  else
    write_delta_active "$(cat "$DEST/theme")"
    echo
    ok "prettiest staged (no shell/git wiring touched)."
    say "test it in a separate terminal — run:  source \"$DEST/prettiest.sh\""
    say "make it permanent later with:  prettiest install"
  fi
  [ "$(os)" = mac ] && say "set that terminal's font to 'MesloLGS Nerd Font' for icons/glyphs"
}

# ---------- theme ----------
cmd_theme(){
  local f="${1:-}" btop_theme
  case " $COLORWAYS " in *" $f "*) ;; *) die "colorway must be one of: $COLORWAYS";; esac
  mkdir -p "$DEST"; echo "$f" > "$DEST/theme"
  # starship palette (palette names equal colorway names)
  { [ -f "$XDG/starship.toml" ] && sed -i.bak -E "s/^palette = .*/palette = \"$f\"/" "$XDG/starship.toml" && rm -f "$XDG/starship.toml.bak"; } || true
  # btop color_theme (catppuccin from fetched file; others from btop's bundled themes by name)
  case "$f" in
    catppuccin) btop_theme="$XDG/btop/themes/catppuccin_mocha.theme" ;;
    gruvbox)    btop_theme="gruvbox_dark" ;;
    tokyonight) btop_theme="tokyo-night" ;;
    mono)       btop_theme="greyscale" ;;
  esac
  if [ -f "$XDG/btop/btop.conf" ]; then
    sed -i.bak -E "s|^color_theme = .*|color_theme = \"$btop_theme\"|" "$XDG/btop/btop.conf" && rm -f "$XDG/btop/btop.conf.bak"
  else
    mkdir -p "$XDG/btop"; printf 'color_theme = "%s"\ntheme_background = False\n' "$btop_theme" > "$XDG/btop/btop.conf"
  fi
  # delta (regenerate active.gitconfig for this colorway)
  write_delta_active "$f"
  ok "colorway set to $f (prompt + delta now; bat/fzf/btop on next shell — re-source or restart)"
}

# ---------- doctor ----------
cmd_doctor(){
  say "tools:"
  for t in $TOOLS; do
    bin="$t"; [ "$t" = git-delta ] && bin=delta
    if have "$bin" || { [ "$t" = bat ] && have batcat; } || { [ "$t" = fd ] && have fdfind; }; then
      ok "$t"; else warn "$t missing"; fi
  done
  say "wiring:"
  grep -q "# $MARKER\$" "$HOME/.zshrc" 2>/dev/null && ok ".zshrc sourced" || warn ".zshrc not wired"
  grep -q "delta/active.gitconfig" "$HOME/.gitconfig" 2>/dev/null && ok "git delta wired" || warn "git delta not wired"
  [ -f "$DEST/theme" ] && say "colorway: $(cat "$DEST/theme")" || warn "no colorway set"
  { have fc-list && { fc-list 2>/dev/null | grep -qi "meslo.*nerd" && ok "Nerd Font present" || warn "MesloLGS Nerd Font not found"; }; } || true
}

# ---------- uninstall ----------
cmd_uninstall(){
  say "removing prettiest wiring (tools are left installed)…"
  for rc in "$HOME/.zshrc" "$HOME/.bashrc"; do
    [ -f "$rc" ] && grep -q "# $MARKER\$" "$rc" && { backup "$rc"; grep -v "# $MARKER\$" "$rc" > "$rc.tmp" && mv "$rc.tmp" "$rc"; ok "unwired $(basename "$rc")"; }
  done
  if grep -q "# --- $MARKER (delta diffs) ---" "$HOME/.gitconfig" 2>/dev/null; then
    backup "$HOME/.gitconfig"
    awk -v m="# --- $MARKER (delta diffs) ---" 'index($0,m){skip=3} skip>0{skip--;next} {print}' "$HOME/.gitconfig" > "$HOME/.gitconfig.tmp" && mv "$HOME/.gitconfig.tmp" "$HOME/.gitconfig"
    ok "removed git delta wiring"
  fi
  rm -rf "$DEST"; ok "removed $DEST"
  say "to remove tools too: brew bundle cleanup --file $ROOT/Brewfile  (review first!)"
}

cmd_help(){ cat <<EOF
prettiest — modern CLI tools + coordinated Catppuccin pretty.

  prettiest install            install tools, fetch themes, wire shell + git
  prettiest install --no-wire  install tools + themes WITHOUT touching shell/git
                               (then test in one terminal: source ~/.config/prettiest/prettiest.sh)
  prettiest theme <colorway>   switch colorway: $COLORWAYS
  prettiest doctor             report what's installed / wired
  prettiest uninstall          remove wiring + configs (keeps tools)
  prettiest help

Disable alias shadowing for a shell:  export PRETTIEST_NO_ALIASES=1
EOF
}

case "${1:-help}" in
  install) shift; cmd_install "${1:-}" ;;
  theme) shift; cmd_theme "${1:-}" ;;
  doctor) cmd_doctor ;;
  uninstall) cmd_uninstall ;;
  help|-h|--help) cmd_help ;;
  *) cmd_help; exit 1 ;;
esac
